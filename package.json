{
  "name": "aiassignment",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter=backend",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/google": "^0.1.12",
    "bullmq": "^5.78.0",
    "ioredis": "^5.11.0",
    "langchain": "^1.4.4",
    "lucide-react": "^1.3.0",
    "socket.io": "^4.8.3"
  }
}
